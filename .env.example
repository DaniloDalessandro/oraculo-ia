# ============================================================
# Oraculo IA — Variaveis de Ambiente
# Copie para .env e preencha com seus valores reais
# ============================================================

# Banco de dados (nomes de servico do docker-compose)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/oraculo
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@db:5432/oraculo
REDIS_URL=redis://redis:6379/0

# Segurança — use uma string aleatória de pelo menos 32 chars
SECRET_KEY=your-super-secret-key-at-least-32-characters-long
ACCESS_TOKEN_EXPIRE_MINUTES=480
LOGIN_TOKEN_EXPIRE_MINUTES=10

# Evolution API — sua instancia do WhatsApp
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE_NAME=oraculo

# URL publica do frontend (usada nos links enviados via WhatsApp)
APP_URL=https://app.seusistema.com

# IA (provedor: "groq", "gemini" ou "openai")
AI_PROVIDER=groq
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=1500
AI_TEMPERATURE=0.1
AI_CONTEXT_SIZE=5
AI_SQL_ROW_LIMIT=50
AI_TIMEOUT_SECONDS=30

# Celery (filas assíncronas)
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_SOFT_TIME_LIMIT=55
CELERY_TASK_TIME_LIMIT=60

# Cache de respostas IA
AI_CACHE_TTL_SECONDS=600
AI_CACHE_ENABLED=true

# Rate limiting por usuário
RATE_LIMIT_PER_MINUTE=5
RATE_LIMIT_BURST=3

# E-mail — recuperacao de senha e notificacoes (use App Password para Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@gmail.com
SMTP_PASSWORD=sua-app-password
SMTP_FROM=noreply@seudominio.com
PASSWORD_RESET_EXPIRE_MINUTES=30

# Seguranca — brute-force e sessoes WhatsApp
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=900
WHATSAPP_SESSION_EXPIRE_HOURS=24
